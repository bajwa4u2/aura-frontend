<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Associated Domains: required for HTTPS Universal Links so a tap on
	  https://auraplatform.org/... opens the app instead of the browser.
	  The matching apple-app-site-association file lives at
	  https://auraplatform.org/.well-known/apple-app-site-association
	  (template under aura_final/web/.well-known/ — operator must
	  replace TEAM_ID with the real Apple Developer Team ID).

	  applinks:auraplatform.org              — primary marketing/auth host
	  applinks:app.auraplatform.org          — authenticated workspace host
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:auraplatform.org</string>
		<string>applinks:app.auraplatform.org</string>
	</array>

	<!--
	  Aps environment: set to "production" because every distribution
	  build (TestFlight and App Store) registers device tokens against
	  the production APNs gateway. The presence of this entitlement is
	  what tells iOS to deliver push notifications at all.

	  The App ID (org.auraplatform.app) must have the Push Notifications
	  capability enabled in the Apple Developer portal, and the App Store
	  provisioning profile must carry that entitlement, or the codesign
	  step of the archive will fail. iOS push is delivered through FCM
	  (the client registers an FCM token); the APNs auth key (.p8) is
	  uploaded to the Firebase Console, not bundled here.
	-->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>

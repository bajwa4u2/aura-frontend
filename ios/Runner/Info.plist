<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Aura</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>aura</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!--
	  Privacy-sensitive APIs the app actually uses. Each NS*UsageDescription
	  is required by App Store review; a missing entry triggers automatic
	  rejection (guideline 5.1.1).

	  Camera: image_picker (avatar / attachment capture), flutter_webrtc
	    (video calls when Pro plan enables realtime).
	  Microphone: record (correspondence audio recording),
	    flutter_webrtc (voice/video calls).
	  Photo library read: image_picker for attachment picking.
	  Photo library add: when the user saves attachment media back to
	    their library (institutional posts, announcements). Apple
	    treats add-only as a distinct authorization.

	  No tracking, no IDFA: NSUserTrackingUsageDescription intentionally
	    omitted. Aura does not use AppTrackingTransparency-gated APIs.
	    If a future SDK pulls in IDFA usage, add the key + prompt then.
	-->
	<key>NSCameraUsageDescription</key>
	<string>Aura uses the camera so you can record video for calls and capture photos for posts, attachments, and your profile.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Aura uses the microphone so you can record voice messages and join voice or video calls.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Aura uses your photo library so you can attach images to posts, messages, and announcements.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Aura asks for permission to save images and downloads to your photo library when you choose to keep them.</string>

	<!--
	  Location: the Aura app itself does not request, store, or share
	  the user's location. This purpose string exists because Apple's
	  static analyzer (`Transporter` / App Store Connect validator,
	  error 90683) flags the binary as referencing CoreLocation through
	  a linked dependency â€” the Firebase iOS SDK pulled in by
	  `firebase_core` / `firebase_messaging` references
	  `CLLocationManager` whether or not the host app calls it. Apple
	  requires a user-facing string for that reference even when the
	  prompt is never triggered. The string is worded so a reviewer can
	  reconcile it with the actual app behaviour (no location feature
	  is wired today; adding one in the future would still honour this
	  string).
	-->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Aura does not currently use your location. This permission is requested only if you later enable a feature that needs it (for example, surfacing nearby live sessions). Your location is never shared.</string>

	<!--
	  Background modes. We claim ONLY the modes the app actually uses:
	    - remote-notification: Firebase Messaging delivers push payloads
	      while the app is suspended (incoming-call ring, message alerts).
	  Each entry must be justifiable to App Store review â€” keep this list
	  minimal. Adding `audio`, `fetch`, or `voip` here without a corresponding
	  feature path (e.g. voip requires PushKit + CallKit) is a rejection trigger.
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!--
	  Custom URL scheme so external links of the form aura://â€¦ can wake
	  the app and route through `app_links` / notification-tap handling.
	  HTTPS Universal Links also work via Associated Domains (declared
	  in Runner.entitlements + apple-app-site-association at the
	  backend domain root).
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>org.auraplatform.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aura</string>
			</array>
		</dict>
	</array>

	<!--
	  Encryption export compliance: app uses only standard HTTPS / WebRTC
	  encryption. Marks the binary as exempt from US export documentation
	  on every TestFlight upload (Apple defaults to "Yes" otherwise and
	  blocks builds until answered).
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>

<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Push notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Audio recording (record package, WebRTC voice calls) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Camera (image_picker, WebRTC video calls) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Camera is optional: app works on camera-less devices -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:label="Aura"
        android:name=".AuraApplication"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Theme visible while Flutter initializes -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Custom URL scheme so external links of the form aura://...
              wake the app and route through `app_links` /
              communication_resolver. Works without domain verification.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="aura" />
            </intent-filter>

            <!--
              HTTPS App Links for auraplatform.org. android:autoVerify="true"
              tells Android to fetch /.well-known/assetlinks.json from the
              host at install time; on success the app handles links to
              these hosts without an "Open with" dialog.

              The assetlinks.json template lives at
              aura_final/web/.well-known/assetlinks.json — operator must
              replace the placeholder SHA-256 fingerprint with the real
              upload+release certificate fingerprints before submitting
              to Play Store.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="auraplatform.org" />
                <data android:scheme="https" android:host="app.auraplatform.org" />
            </intent-filter>

        </activity>

        <!-- Flutter engine registration -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Default FCM channel for incoming-call ringing. Channel itself is
             created at process start in AuraApplication.onCreate(). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="aura_calls" />

    </application>

    <!-- Required for text processing plugins -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

</manifest>
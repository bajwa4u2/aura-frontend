# Server
PORT=3000

# Database
# Postgres connection string used by Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aura?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# CORS
# Comma-separated allowed origins. Include your frontend domain(s).
# Example:
# CORS_ORIGINS=https://aura.bajwawrites.com,https://bajwawrites.com,http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

FROM node:22-alpine

WORKDIR /app

# System deps for prisma + basic tooling
RUN apk add --no-cache libc6-compat openssl

# Install deps first (better caching)
COPY package*.json ./
RUN npm ci || npm i

# Copy source
COPY . .

# Generate prisma client inside container
RUN npx prisma generate

EXPOSE 3000
CMD ["npm", "run", "start:dev"]

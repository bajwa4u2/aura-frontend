generator client {
  provider      = "prisma-client-js"
  // Targets to support:
  // - WSL on Windows ARM64 (linux-arm64-openssl-3.0.x)
  // - Typical Railway Linux x64 Node images (debian-openssl-3.0.x)
  // Keep "native" so local generation matches the current environment.
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum PostVisibility {
  PUBLIC
  ARCHIVED
}

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum EmailOutboxStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  handle       String   @unique
  displayName  String?
  bio          String?
  avatarUrl    String?
  passwordHash String

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions      UserSession[]
  posts         Post[]
  reactions     Reaction[]
  saves         Save[]
  notifications Notification[]
  authTokens    AuthToken[]
  emailOutbox   EmailOutbox[]

  @@index([createdAt])
  @@index([handle])
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Post {
  id       String @id @default(cuid())
  authorId String
  text     String

  status     PostStatus     @default(PUBLISHED)
  visibility PostVisibility @default(PUBLIC)

  repostOfPostId String?
  parentId       String?
  replyToPostId  String?

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  repostOfPost Post?  @relation("RepostRelation", fields: [repostOfPostId], references: [id], onDelete: Cascade)
  reposts      Post[] @relation("RepostRelation")

  parent  Post?  @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Post[] @relation("PostReplies")

  replyToPost Post?  @relation("ReplyToPost", fields: [replyToPostId], references: [id], onDelete: Cascade)
  replyPosts  Post[] @relation("ReplyToPost")

  reactions     Reaction[]
  saves         Save[]
  notifications Notification[]

  @@index([authorId, createdAt])
  @@index([status, createdAt])
  @@index([visibility, createdAt])
  @@index([parentId, createdAt])
  @@index([replyToPostId, createdAt])
  @@index([repostOfPostId, createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  createdAt DateTime @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([postId, createdAt])
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  type      AuthTokenType
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, expiresAt])
}

model EmailOutbox {
  id String @id @default(cuid())

  // Optional link to a user (keeps system emails possible)
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  to       String
  subject  String
  bodyHtml String?
  bodyText String?
  status   EmailOutboxStatus @default(PENDING)
  error    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sentAt    DateTime?

  @@index([userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

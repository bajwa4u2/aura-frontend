# ----------------------------------------
# Server
# ----------------------------------------
PORT=3000

# ----------------------------------------
# Database
# Postgres connection string used by Prisma
# ----------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aura?schema=public

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------
# JWT
# IMPORTANT:
# Replace these with strong random values before production.
# ----------------------------------------
JWT_ACCESS_SECRET=local_access_super_secret_key_123
JWT_REFRESH_SECRET=local_refresh_super_secret_key_123
JWT_SECRET=local_master_secret_key_123

# ----------------------------------------
# CORS
# Comma-separated allowed origins.
# Update when deploying.
# ----------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://aura.bajwadynesty.us,https://bajwadynesty.us
